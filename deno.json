{
  "tasks": {
    "run": "deno run --allow-env=AGENTIC_ROUTER_DB_PATH,DENO_SQLITE_PATH,DENO_SQLITE_LOCAL,DENO_DIR,HOME --allow-read --allow-write --allow-ffi --allow-net=github.com,release-assets.githubusercontent.com src/main.ts",
    "serve": "deno run --unstable-no-legacy-abort --allow-env=AGENTIC_ROUTER_DB_PATH,AGENTIC_ROUTER_HOST,AGENTIC_ROUTER_PORT,DENO_SQLITE_PATH,DENO_SQLITE_LOCAL,DENO_DIR,HOME --allow-read --allow-write --allow-ffi --allow-net=127.0.0.1,github.com,release-assets.githubusercontent.com src/http_main.ts",
    "check": "deno check src/main.ts src/http_main.ts",
    "test": "deno test --allow-env --allow-read --allow-write --allow-ffi --allow-net=github.com,release-assets.githubusercontent.com",
    "lint": "deno lint",
    "fmt": "deno fmt --check deno.json src"
  },
  "imports": {
    "@db/sqlite": "jsr:@db/sqlite@^0.13.0",
    "@mcp/server": "npm:@modelcontextprotocol/sdk@^1.17.5/server/mcp.js",
    "@mcp/stdio": "npm:@modelcontextprotocol/sdk@^1.17.5/server/stdio.js",
    "@mcp/types": "npm:@modelcontextprotocol/sdk@^1.17.5/types.js",
    "@mcp/web-http": "npm:@modelcontextprotocol/sdk@^1.17.5/server/webStandardStreamableHttp.js",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "@std/path": "jsr:@std/path@^1.1.6",
    "@src/": "./src/",
    "zod": "npm:zod@^4.1.12",
    "zod/v4": "npm:zod@^4.1.12/v4"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"],
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false
  }
}
